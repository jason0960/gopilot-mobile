{
  "expo": {
    "name": "AgentDeck Command Center",
    "description": "Control GitHub Copilot Chat from your phone — agent mode, file browser, git changes, terminal, and more.",
    "slug": "gopilot",
    "version": "0.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1e1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mobilecopilot.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan QR codes for pairing with VS Code",
        "NSLocalNetworkUsageDescription": "Local network access is used to connect to VS Code on your computer",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e1e1e"
      },
      "package": "com.mobilecopilot.app",
      "permissions": [
        "CAMERA"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "scheme": "agentdeck",
    "owner": "jason096",
    "extra": {
      "eas": {
        "projectId": "5b3d2b57-ed1a-41c1-90e2-27e00e5c40f1"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": false
    }
  }
}
