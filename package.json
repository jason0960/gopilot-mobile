{
  "name": "gopilot-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "start": "CI=1 EXPO_NO_TYPESCRIPT_SETUP=1 expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "CI=1 EXPO_NO_TYPESCRIPT_SETUP=1 expo start --web",
    "build:dev": "eas build --profile development --platform ios",
    "build:preview": "eas build --profile preview --platform ios",
    "build:production": "eas build --profile production --platform ios",
    "submit": "eas submit --platform ios",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/native": "^7.1.6",
    "expo": "~54.0.0",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-haptics": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "merge-options": "^3.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tweetnacl": "^1.0.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.0",
    "eas-cli": "^18.3.0",
    "jest": "~29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  }
}
